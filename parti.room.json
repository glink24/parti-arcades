    "worker": "room.worker.js"
  },
  "room": {
    "minPlayers": 2,
    "maxPlayers": 6
  },
  "sync": {
    "mode": "snapshot"
  },
  "permissions": {
    "network": false,
    "storage": "session"
  }
}
